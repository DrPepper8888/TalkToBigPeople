.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #f5f5f5;
}

.chat-container {
  flex: 1;
  padding: 20rpx;
}

/* ========== 欢迎语 ========== */
.welcome-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 40rpx 80rpx;
  text-align: center;
}

.welcome-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  font-size: 48rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.3);
}

.welcome-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 15rpx;
}

.welcome-desc {
  font-size: 28rpx;
  color: #999;
}

/* ========== 消息列表 ========== */
.message-list {
  display: flex;
  flex-direction: column;
  gap: 30rpx;
}

.message-item {
  display: flex;
  gap: 20rpx;
  max-width: 80%;
}

.message-item.user {
  flex-direction: row-reverse;
  align-self: flex-end;
}

.message-item.assistant {
  align-self: flex-start;
}

.avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
  flex-shrink: 0;
}

.message-item.user .avatar {
  background: linear-gradient(135deg, #07c160 0%, #05a854 100%);
  color: #fff;
}

.message-item.assistant .avatar {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
}

.message-content {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.message-bubble {
  padding: 24rpx 30rpx;
  border-radius: 24rpx;
  font-size: 30rpx;
  line-height: 1.6;
  word-break: break-all;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.message-item.user .message-bubble {
  background: linear-gradient(135deg, #07c160 0%, #05a854 100%);
  color: #fff;
  border-bottom-right-radius: 8rpx;
}

.message-item.assistant .message-bubble {
  background: #fff;
  color: #333;
  border-bottom-left-radius: 8rpx;
}

.generating-dot {
  display: inline-block;
  color: #999;
  animation: pulse 1.5s infinite;
}

@keyframes pulse {
  0%, 100% {
    opacity: 0.4;
  }
  50% {
    opacity: 1;
  }
}

.message-time {
  font-size: 22rpx;
  color: #bbb;
  padding: 0 10rpx;
}

.message-item.user .message-time {
  text-align: right;
}

.message-item.assistant .message-time {
  text-align: left;
}

.bottom-space {
  height: 40rpx;
}

/* ========== 输入栏 ========== */
.input-bar {
  background: #fff;
  padding: 20rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  display: flex;
  align-items: flex-end;
  gap: 16rpx;
  border-top: 1rpx solid #eee;
  box-shadow: 0 -4rpx 12rpx rgba(0, 0, 0, 0.04);
}

.clear-btn {
  width: 72rpx;
  height: 72rpx;
  padding: 0;
  margin: 0;
  background: #f5f5f5;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  border: none;
  flex-shrink: 0;
  line-height: 1;
}

.clear-btn::after {
  border: none;
}

.input-area {
  flex: 1;
  min-height: 72rpx;
  max-height: 240rpx;
  padding: 18rpx 24rpx;
  background: #f5f5f5;
  border-radius: 16rpx;
  font-size: 30rpx;
  line-height: 1.5;
  box-sizing: border-box;
}

.send-btn {
  height: 72rpx;
  padding: 0 32rpx;
  background: linear-gradient(135deg, #07c160 0%, #05a854 100%);
  color: #fff;
  border-radius: 16rpx;
  font-size: 28rpx;
  border: none;
  margin: 0;
  flex-shrink: 0;
  line-height: 72rpx;
}

.send-btn.disabled {
  background: #ccc;
  color: #fff;
}

.send-btn::after {
  border: none;
}

/* ========== 错误提示条 ========== */
.error-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  background: linear-gradient(135deg, #fa5151 0%, #ff7875 100%);
  color: #fff;
  padding: 24rpx 30rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  z-index: 1000;
  box-shadow: 0 4rpx 12rpx rgba(250, 81, 81, 0.2);
}

.error-bar-icon {
  font-size: 32rpx;
  flex-shrink: 0;
}

.error-bar-text {
  flex: 1;
  font-size: 26rpx;
  line-height: 1.4;
}

.error-bar-close {
  font-size: 40rpx;
  opacity: 0.8;
  flex-shrink: 0;
  line-height: 1;
}
