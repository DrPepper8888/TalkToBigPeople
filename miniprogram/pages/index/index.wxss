.container {
  padding: 20rpx;
  min-height: 100vh;
  background-color: #f5f5f5;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  text-align: center;
  margin: 40rpx 0 20rpx;
  color: #333;
}

.subtitle {
  font-size: 28rpx;
  text-align: center;
  color: #666;
  margin-bottom: 40rpx;
}

.create-section {
  margin-bottom: 40rpx;
  padding: 0 10rpx;
}

.create-btn {
  width: 100%;
  background-color: #07c160;
  color: #fff;
  border-radius: 16rpx;
  line-height: 88rpx;
  height: 88rpx;
  font-size: 32rpx;
}

.section {
  margin-bottom: 40rpx;
}

.section-title {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 20rpx;
  padding-left: 10rpx;
}

.list {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.item {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  transition: all 0.2s;
  border: 1rpx solid #eee;
}

.custom-item {
  display: flex;
  padding: 0;
}

.item-content {
  flex: 1;
  padding: 30rpx;
  border-radius: 16rpx 0 0 16rpx;
  background-color: #fff;
}

.delete-btn {
  width: 120rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #ff4d4f;
  color: #fff;
  border-radius: 0 16rpx 16rpx 0;
  font-size: 24rpx;
}

.item:active {
  transform: scale(0.98);
  background-color: #f0f8ff;
  border-color: #1677ff;
}

.name {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 8rpx;
}

.desc {
  font-size: 24rpx;
  color: #888;
}

.footer {
  margin-top: 40rpx;
  padding: 20rpx;
}

.tips {
  font-size: 24rpx;
  color: #999;
  text-align: center;
  line-height: 1.5;
}

.loading {
  text-align: center;
  padding: 40rpx;
  color: #666;
  font-size: 28rpx;
}
