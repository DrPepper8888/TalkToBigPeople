.container {
  padding: 20rpx;
  min-height: 100vh;
  background-color: #f5f5f5;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  text-align: center;
  margin: 40rpx 0 20rpx;
  color: #333;
}

.subtitle {
  font-size: 28rpx;
  text-align: center;
  color: #666;
  margin-bottom: 40rpx;
}

/* ========== 骨架屏样式 ========== */
.skeleton-container {
  padding: 0 10rpx;
}

.skeleton-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
  background-size: 200% 100%;
  animation: skeleton-loading 1.5s infinite;
  border-radius: 16rpx;
  margin-bottom: 40rpx;
}

.skeleton-section {
  margin-bottom: 40rpx;
}

.skeleton-title {
  width: 160rpx;
  height: 32rpx;
  background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
  background-size: 200% 100%;
  animation: skeleton-loading 1.5s infinite;
  border-radius: 8rpx;
  margin-bottom: 20rpx;
}

.skeleton-item {
  height: 120rpx;
  background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
  background-size: 200% 100%;
  animation: skeleton-loading 1.5s infinite;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}

@keyframes skeleton-loading {
  0% {
    background-position: 200% 0;
  }
  100% {
    background-position: -200% 0;
  }
}

/* ========== 错误状态 ========== */
.error-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 40rpx;
  text-align: center;
}

.error-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.error-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

.error-desc {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  margin-bottom: 40rpx;
  white-space: pre-line;
}

.retry-btn {
  background-color: #1677ff;
  color: #fff;
  border-radius: 12rpx;
  padding: 0 60rpx;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 30rpx;
}

/* ========== 空状态 ========== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 40rpx;
  text-align: center;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 10rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #999;
}

/* ========== 工具栏 ========== */
.toolbar {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 30rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.toolbar-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
}

.toolbar-btns {
  display: flex;
  gap: 16rpx;
}

.tool-btn {
  padding: 12rpx 24rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  border: none;
  margin: 0;
  line-height: 1.2;
}

.tool-btn.export {
  background: #e6f4ff;
  color: #1677ff;
}

.tool-btn.import {
  background: #f6ffed;
  color: #52c41a;
}

/* ========== 内容区域 ========== */
.create-section {
  margin-bottom: 40rpx;
  padding: 0 10rpx;
}

.create-btn {
  width: 100%;
  background-color: #07c160;
  color: #fff;
  border-radius: 16rpx;
  line-height: 88rpx;
  height: 88rpx;
  font-size: 32rpx;
}

.section {
  margin-bottom: 40rpx;
}

.section-title {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 20rpx;
  padding-left: 10rpx;
}

.list {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.item {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  transition: all 0.2s;
  border: 1rpx solid #eee;
  position: relative;
}

.custom-item {
  display: flex;
  padding: 0;
}

.item-content {
  flex: 1;
  padding: 30rpx;
  border-radius: 16rpx 0 0 16rpx;
  background-color: #fff;
}

.delete-btn {
  width: 120rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #ff4d4f;
  color: #fff;
  border-radius: 0 16rpx 16rpx 0;
  font-size: 24rpx;
}

.item:active {
  transform: scale(0.98);
  background-color: #f0f8ff;
  border-color: #1677ff;
}

.name {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 8rpx;
}

.desc {
  font-size: 24rpx;
  color: #888;
}

.built-badge {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  font-size: 20rpx;
  color: #1677ff;
  background: #e6f4ff;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.footer {
  margin-top: 40rpx;
  padding: 20rpx;
}

.tips {
  font-size: 24rpx;
  color: #999;
  text-align: center;
  line-height: 1.5;
}

.loading {
  text-align: center;
  padding: 40rpx;
  color: #666;
  font-size: 28rpx;
}

/* ========== 导入对话框 ========== */
.dialog-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.dialog-content {
  width: 85%;
  max-height: 80vh;
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.dialog-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  border-bottom: 1rpx solid #eee;
}

.dialog-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.dialog-close {
  font-size: 48rpx;
  color: #999;
  line-height: 1;
}

.dialog-body {
  padding: 30rpx;
  flex: 1;
  overflow-y: auto;
}

.dialog-hint {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 20rpx;
  display: block;
}

.import-textarea {
  width: 100%;
  min-height: 300rpx;
  padding: 20rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  font-size: 24rpx;
  color: #333;
  box-sizing: border-box;
}

.dialog-tips {
  font-size: 24rpx;
  color: #1677ff;
  margin-top: 16rpx;
  display: block;
}

.dialog-actions {
  display: flex;
  border-top: 1rpx solid #eee;
  padding: 20rpx 30rpx 30rpx;
  gap: 20rpx;
}

.dialog-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  border: none;
  margin: 0;
}

.dialog-btn.cancel {
  background: #f5f5f5;
  color: #666;
}

.dialog-btn.confirm {
  background: #1677ff;
  color: #fff;
}
