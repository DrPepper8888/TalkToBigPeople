.container {
  padding: 20rpx;
  min-height: 100vh;
  background-color: #f5f5f5;
}

.form {
  background-color: #fff;
  border-radius: 8rpx;
  padding: 30rpx;
}

.form-item {
  margin-bottom: 30rpx;
}

.label {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 16rpx;
}

.label-sm {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin: 12rpx 0 8rpx 0;
}

.input {
  width: 100%;
  height: 70rpx;
  border: 1rpx solid #ddd;
  border-radius: 8rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.input-sm {
  width: 100%;
  height: 60rpx;
  border: 1rpx solid #ddd;
  border-radius: 8rpx;
  padding: 0 16rpx;
  font-size: 26rpx;
  box-sizing: border-box;
}

.textarea {
  width: 100%;
  min-height: 200rpx;
  border: 1rpx solid #ddd;
  border-radius: 8rpx;
  padding: 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.textarea-sm {
  width: 100%;
  min-height: 120rpx;
  border: 1rpx solid #ddd;
  border-radius: 8rpx;
  padding: 16rpx;
  font-size: 26rpx;
  box-sizing: border-box;
}

.section-title {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title text {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.add-btn {
  font-size: 24rpx;
  color: #07c160;
  padding: 0 16rpx;
  line-height: 48rpx;
  height: 48rpx;
}

.work-item {
  background-color: #fafafa;
  border-radius: 8rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid #eee;
}

.work-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.work-header text:first-child {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
}

.delete {
  font-size: 24rpx;
  color: #ff4d4f;
}

.tips {
  font-size: 24rpx;
  color: #999;
  margin: 20rpx 0 30rpx 0;
}

.submit-btn {
  width: 100%;
  background-color: #07c160;
  color: #fff;
  border-radius: 8rpx;
  line-height: 88rpx;
  height: 88rpx;
  font-size: 32rpx;
}
