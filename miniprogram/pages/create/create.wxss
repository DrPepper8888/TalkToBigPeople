.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 20rpx;
}

/* ========== 草稿提示 ========== */
.draft-tip {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 20rpx 24rpx;
  background: #fff7e6;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid #ffd591;
}

.draft-icon {
  font-size: 28rpx;
}

.draft-text {
  flex: 1;
  font-size: 24rpx;
  color: #d46b08;
}

.draft-clear {
  font-size: 24rpx;
  color: #fa5151;
  padding: 8rpx 16rpx;
}

/* ========== 表单样式 ========== */
.form {
  padding-bottom: 60rpx;
}

.form-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.label {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 16rpx;
}

.input {
  width: 100%;
  padding: 20rpx 0;
  font-size: 28rpx;
  color: #333;
  border-bottom: 1rpx solid #eee;
}

.textarea {
  width: 100%;
  min-height: 160rpx;
  padding: 20rpx 0;
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
}

/* ========== 作品区域 ========== */
.section-title {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  margin-top: 20rpx;
}

.section-title text {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
}

.add-btn {
  padding: 12rpx 24rpx;
  background: #e6f4ff;
  color: #1677ff;
  border-radius: 8rpx;
  font-size: 26rpx;
  border: none;
  margin: 0;
  line-height: 1.2;
}

.add-btn::after {
  border: none;
}

.work-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.work-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.work-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
}

.work-delete {
  font-size: 24rpx;
  color: #fa5151;
  padding: 8rpx 16rpx;
}

.label-sm {
  display: block;
  font-size: 24rpx;
  color: #666;
  margin: 16rpx 0 8rpx;
}

.input-sm {
  width: 100%;
  padding: 16rpx 0;
  font-size: 26rpx;
  color: #333;
  border-bottom: 1rpx solid #eee;
}

.textarea-sm {
  width: 100%;
  min-height: 100rpx;
  padding: 12rpx 0;
  font-size: 26rpx;
  color: #333;
  line-height: 1.6;
}

/* ========== 空状态 ========== */
.empty-works {
  background: #fff;
  border-radius: 16rpx;
  padding: 60rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.empty-icon {
  font-size: 60rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 8rpx;
}

.empty-desc {
  font-size: 24rpx;
  color: #999;
}

/* ========== 提示文字 ========== */
.tips {
  display: flex;
  gap: 12rpx;
  padding: 30rpx 20rpx;
  margin: 20rpx 0;
}

.tips-icon {
  font-size: 28rpx;
}

.tips-text {
  flex: 1;
  font-size: 24rpx;
  color: #999;
  line-height: 1.6;
}

/* ========== 提交按钮 ========== */
.submit-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: linear-gradient(135deg, #07c160 0%, #05a854 100%);
  color: #fff;
  border-radius: 16rpx;
  font-size: 32rpx;
  border: none;
  margin-top: 20rpx;
}

.submit-btn::after {
  border: none;
}

.submit-btn[disabled] {
  background: #ccc;
  color: #fff;
}
