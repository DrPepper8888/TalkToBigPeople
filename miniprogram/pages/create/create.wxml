<view class="container">
  <!-- 草稿提示 -->
  <view class="draft-tip" wx:if="{{hasDraft}}">
    <text class="draft-icon">💾</text>
    <text class="draft-text">已自动保存草稿</text>
    <text class="draft-clear" catchtap="clearDraftConfirm">清除</text>
  </view>

  <view class="form">
    <view class="form-item">
      <text class="label">人物名称 *</text>
      <input class="input" placeholder="比如：苏轼、李白、爱因斯坦" value="{{name}}" bindinput="onNameInput" maxlength="50" />
    </view>

    <view class="form-item">
      <text class="label">简短描述 *</text>
      <input class="input" placeholder="一句话描述，比如：宋代文豪，豁达乐观" value="{{description}}" bindinput="onDescInput" maxlength="100" />
    </view>

    <view class="form-item">
      <text class="label">人物传记/核心思想</text>
      <textarea class="textarea" placeholder="详细介绍这个人物的生平、核心思想、性格特点，帮助 AI 更准确地模仿" value="{{biography}}" bindinput="onBioInput" maxlength="2000" auto-height />
    </view>

    <view class="form-item">
      <text class="label">名人名言（每行一句）</text>
      <textarea class="textarea" placeholder="比如：&#10;「但愿人长久，千里共婵娟。」&#10;「竹杖芒鞋轻胜马，谁怕？一蓑烟雨任平生。」" value="{{famousQuotesText}}" bindinput="onQuotesInput" maxlength="2000" auto-height />
    </view>

    <view class="section-title">
      <text>📚 核心作品</text>
      <button class="add-btn" bindtap="addWork">+ 添加作品</button>
    </view>

    <view class="work-item" wx:for="{{works}}" wx:key="index">
      <view class="work-header">
        <text class="work-title">作品 {{index + 1}}</text>
        <text class="work-delete" catchtap="deleteWork" data-index="{{index}}">删除</text>
      </view>
      <input class="input-sm" placeholder="作品标题（如：水调歌头·明月几时有）" value="{{item.title}}" bindinput="onWorkTitleInput" data-index="{{index}}" maxlength="100" />
      <text class="label-sm">📖 原文</text>
      <textarea class="textarea-sm" placeholder="作品原文内容" value="{{item.originalText}}" bindinput="onWorkOriginalInput" data-index="{{index}}" maxlength="2000" />
      <text class="label-sm">💬 现代文翻译</text>
      <textarea class="textarea-sm" placeholder="翻译成现代文，帮助用户理解" value="{{item.modernTranslation}}" bindinput="onWorkTranslationInput" data-index="{{index}}" maxlength="2000" />
      <text class="label-sm">💡 注释/背景说明</text>
      <textarea class="textarea-sm" placeholder="这篇作品的创作背景、中心思想说明" value="{{item.explanation}}" bindinput="onWorkExplanationInput" data-index="{{index}}" maxlength="1000" />
    </view>

    <view class="empty-works" wx:if="{{works.length === 0}}">
      <text class="empty-icon">📝</text>
      <text class="empty-text">暂未添加作品</text>
      <text class="empty-desc">点击上方「添加作品」按钮添加</text>
    </view>

    <view class="tips">
      <text class="tips-icon">ℹ️</text>
      <text class="tips-text">* 标记为必填项，名人名言和作品可以留空，后续再补充。数据会自动保存为草稿，不用担心丢失。</text>
    </view>

    <button
      class="submit-btn"
      type="primary"
      bindtap="submit"
      loading="{{submitting}}"
      disabled="{{submitting || !name.trim() || !description.trim()}}"
    >
      {{submitting ? '创建中...' : '✨ 创建人物'}}
    </button>
  </view>
</view>
